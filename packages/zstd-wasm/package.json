{
  "name": "@tootallnate/zstd-wasm",
  "version": "0.0.2",
  "description": "Zstandard decoder with a streaming TransformStream API.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./zstd.wasm": "./dist/zstd.wasm"
  },
  "files": [
    "dist",
    "c/ZSTD-LICENSE"
  ],
  "scripts": {
    "build:wasm": "make",
    "build:ts": "tsc",
    "build": "if [ -x /tmp/wasi-sdk/bin/clang ]; then make; fi && tsc && cp src/zstd.wasm dist/zstd.wasm",
    "test": "vitest run"
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TooTallNate/switch-tools",
    "directory": "packages/zstd-wasm"
  }
}
