{
  "name": "@tootallnate/bink1-wasm",
  "version": "0.0.1",
  "description": "WebAssembly decoder for Bink 1 (.bik) video, built from a slim ffmpeg config (bink-decoder + binkaudio + bink-demuxer only). Ships the compiled bink1.wasm directly — ffmpeg is LGPL-2.1 so redistribution is allowed.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./bink1.wasm": "./dist/bink1.wasm"
  },
  "files": [
    "dist",
    "c/wrapper.c",
    "c/patches",
    "scripts",
    "Makefile",
    "README.md",
    "LICENSE.LGPL-2.1"
  ],
  "scripts": {
    "build:ts": "tsc && cp src/bink1.wasm dist/bink1.wasm",
    "build:wasm": "make",
    "build": "tsc && cp src/bink1.wasm dist/bink1.wasm",
    "setup-source": "bash scripts/setup-source.sh",
    "test": "vitest run"
  },
  "license": "LGPL-2.1-or-later",
  "author": "Nathan Rajlich <n@n8.io>",
  "repository": {
    "type": "git",
    "url": "https://github.com/TooTallNate/switch-tools",
    "directory": "packages/bink1-wasm"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
