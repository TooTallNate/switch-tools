{
  "name": "@tootallnate/ffmpeg-bink-audio-wasm",
  "version": "0.0.1",
  "type": "module",
  "description": "Bink audio decoder extension for @tootallnate/ffmpeg-wasm.",
  "exports": {
    "./bink-audio.so": "./dist/bink-audio.so"
  },
  "files": [
    "dist",
    "LICENSE.LGPL-2.1"
  ],
  "scripts": {
    "build:wasm": "make",
    "build": "if [ -x /tmp/wasi-sdk/bin/clang ] && [ -d ../ffmpeg-wasm/build/ffmpeg ]; then make; fi && mkdir -p dist && cp src/bink-audio.so dist/bink-audio.so"
  },
  "keywords": [
    "ffmpeg",
    "wasm",
    "bink",
    "audio",
    "binkaudio"
  ],
  "author": "Nathan Rajlich <n@n8.io>",
  "license": "LGPL-2.1-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/TooTallNate/switch-tools",
    "directory": "packages/ffmpeg-bink-audio-wasm"
  },
  "devDependencies": {
    "@tootallnate/ffmpeg-wasm": "workspace:*"
  }
}
