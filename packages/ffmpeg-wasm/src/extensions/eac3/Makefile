# @tootallnate/ffmpeg-wasm/extensions/eac3
#
# EAC3 decoder, encoder, demuxer, muxer.
#
# AUTOGENERATED by scripts/gen/. Do not edit by hand — re-run
# the generator after changing the upstream FFmpeg checkout.

WASI_SDK_VERSION ?= 25
WASI_SDK ?= /tmp/wasi-sdk
CC      = $(WASI_SDK)/bin/clang
WASM_LD = $(WASI_SDK)/bin/wasm-ld

SYSROOT = $(WASI_SDK)/share/wasi-sysroot

FFMPEG_BASE = ../../../build/ffmpeg
SHARED_INC  = ../../../c

OUT = eac3.so

BASE_CFLAGS = \
	--target=wasm32-wasip1 \
	--sysroot=$(SYSROOT) \
	-fPIC \
	-fvisibility=hidden \
	-O2 \
	-DHAVE_AV_CONFIG_H \
	-I$(FFMPEG_BASE) \
	-I$(FFMPEG_BASE)/libavcodec \
	-I$(FFMPEG_BASE)/libavformat \
	-I$(SHARED_INC) \
	-include shim.h \
	-include libavutil/internal.h \
	-Wno-implicit-fallthrough \
	-Wno-deprecated-declarations \
	-Wno-incompatible-pointer-types \
	-Wno-unused-but-set-variable \
	-Wno-unused-variable \
	-Wno-unused-function \
	-Wno-pointer-sign \
	-Wno-bitwise-op-parentheses \
	-Wno-shift-op-parentheses

LDFLAGS = \
	--shared \
	--no-entry \
	--export-dynamic \
	--allow-undefined \
	--gc-sections

.PHONY: all clean check-base

all: check-base $(OUT)

check-base:
	@if [ ! -d "$(FFMPEG_BASE)" ]; then \
		echo "ERROR: base FFmpeg checkout not found at $(FFMPEG_BASE)"; \
		echo "Run 'make setup-source' in $(realpath $(FFMPEG_BASE)/../..) first."; \
		exit 1; \
	fi

build:
	@mkdir -p build

build/init.o: init.c shim.h | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_aac_ac3_parser.o: ../../../build/ffmpeg/libavcodec/aac_ac3_parser.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_ac3_channel_layout_tab.o: ../../../build/ffmpeg/libavcodec/ac3_channel_layout_tab.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_ac3.o: ../../../build/ffmpeg/libavcodec/ac3.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_ac3dec_data.o: ../../../build/ffmpeg/libavcodec/ac3dec_data.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_ac3dec_float.o: ../../../build/ffmpeg/libavcodec/ac3dec_float.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_ac3dsp.o: ../../../build/ffmpeg/libavcodec/ac3dsp.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_ac3enc_float.o: ../../../build/ffmpeg/libavcodec/ac3enc_float.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_ac3enc.o: ../../../build/ffmpeg/libavcodec/ac3enc.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_ac3tab.o: ../../../build/ffmpeg/libavcodec/ac3tab.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_eac3_data.o: ../../../build/ffmpeg/libavcodec/eac3_data.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_eac3enc.o: ../../../build/ffmpeg/libavcodec/eac3enc.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_fmtconvert.o: ../../../build/ffmpeg/libavcodec/fmtconvert.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_kbdwin.o: ../../../build/ffmpeg/libavcodec/kbdwin.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavformat_ac3dec.o: ../../../build/ffmpeg/libavformat/ac3dec.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavformat_rawdec.o: ../../../build/ffmpeg/libavformat/rawdec.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavformat_rawenc.o: ../../../build/ffmpeg/libavformat/rawenc.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

$(OUT): build/libavcodec_aac_ac3_parser.o build/libavcodec_ac3_channel_layout_tab.o build/libavcodec_ac3.o build/libavcodec_ac3dec_data.o build/libavcodec_ac3dec_float.o build/libavcodec_ac3dsp.o build/libavcodec_ac3enc_float.o build/libavcodec_ac3enc.o build/libavcodec_ac3tab.o build/libavcodec_eac3_data.o build/libavcodec_eac3enc.o build/libavcodec_fmtconvert.o build/libavcodec_kbdwin.o build/libavformat_ac3dec.o build/libavformat_rawdec.o build/libavformat_rawenc.o build/init.o
	$(WASM_LD) $(LDFLAGS) -o $@ build/libavcodec_aac_ac3_parser.o build/libavcodec_ac3_channel_layout_tab.o build/libavcodec_ac3.o build/libavcodec_ac3dec_data.o build/libavcodec_ac3dec_float.o build/libavcodec_ac3dsp.o build/libavcodec_ac3enc_float.o build/libavcodec_ac3enc.o build/libavcodec_ac3tab.o build/libavcodec_eac3_data.o build/libavcodec_eac3enc.o build/libavcodec_fmtconvert.o build/libavcodec_kbdwin.o build/libavformat_ac3dec.o build/libavformat_rawdec.o build/libavformat_rawenc.o build/init.o
	@echo "Built $(OUT) ($$(wc -c < $(OUT) | tr -d ' ') bytes)"

clean:
	rm -rf build $(OUT)
