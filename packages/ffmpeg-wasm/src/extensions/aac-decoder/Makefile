# @tootallnate/ffmpeg-wasm/extensions/aac-decoder
#
# AAC decoder.
#
# AUTOGENERATED by scripts/gen/. Do not edit by hand — re-run
# the generator after changing the upstream FFmpeg checkout.

WASI_SDK_VERSION ?= 25
WASI_SDK ?= /tmp/wasi-sdk
CC      = $(WASI_SDK)/bin/clang
WASM_LD = $(WASI_SDK)/bin/wasm-ld

SYSROOT = $(WASI_SDK)/share/wasi-sysroot

FFMPEG_BASE = ../../../build/ffmpeg
SHARED_INC  = ../../../c

OUT = aac-decoder.so

BASE_CFLAGS = \
	--target=wasm32-wasip1 \
	--sysroot=$(SYSROOT) \
	-fPIC \
	-fvisibility=hidden \
	-O2 \
	-DHAVE_AV_CONFIG_H \
	-I$(FFMPEG_BASE) \
	-I$(FFMPEG_BASE)/libavcodec \
	-I$(FFMPEG_BASE)/libavformat \
	-I$(SHARED_INC) \
	-include shim.h \
	-include libavutil/internal.h \
	-Wno-implicit-fallthrough \
	-Wno-deprecated-declarations \
	-Wno-incompatible-pointer-types \
	-Wno-unused-but-set-variable \
	-Wno-unused-variable \
	-Wno-unused-function \
	-Wno-pointer-sign \
	-Wno-bitwise-op-parentheses \
	-Wno-shift-op-parentheses

LDFLAGS = \
	--shared \
	--no-entry \
	--export-dynamic \
	--allow-undefined \
	--gc-sections

.PHONY: all clean check-base

all: check-base $(OUT)

check-base:
	@if [ ! -d "$(FFMPEG_BASE)" ]; then \
		echo "ERROR: base FFmpeg checkout not found at $(FFMPEG_BASE)"; \
		echo "Run 'make setup-source' in $(realpath $(FFMPEG_BASE)/../..) first."; \
		exit 1; \
	fi

build:
	@mkdir -p build

build/init.o: init.c shim.h | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_aacdec.o: ../../../build/ffmpeg/libavcodec/aacdec.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_aacps_common.o: ../../../build/ffmpeg/libavcodec/aacps_common.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_aacps_float.o: ../../../build/ffmpeg/libavcodec/aacps_float.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_aacpsdsp_float.o: ../../../build/ffmpeg/libavcodec/aacpsdsp_float.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_aacsbr.o: ../../../build/ffmpeg/libavcodec/aacsbr.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_aactab.o: ../../../build/ffmpeg/libavcodec/aactab.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_adts_header.o: ../../../build/ffmpeg/libavcodec/adts_header.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_cbrt_data.o: ../../../build/ffmpeg/libavcodec/cbrt_data.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_kbdwin.o: ../../../build/ffmpeg/libavcodec/kbdwin.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_mdct15.o: ../../../build/ffmpeg/libavcodec/mdct15.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_mpeg4audio_sample_rates.o: ../../../build/ffmpeg/libavcodec/mpeg4audio_sample_rates.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_sbrdsp.o: ../../../build/ffmpeg/libavcodec/sbrdsp.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

$(OUT): build/libavcodec_aacdec.o build/libavcodec_aacps_common.o build/libavcodec_aacps_float.o build/libavcodec_aacpsdsp_float.o build/libavcodec_aacsbr.o build/libavcodec_aactab.o build/libavcodec_adts_header.o build/libavcodec_cbrt_data.o build/libavcodec_kbdwin.o build/libavcodec_mdct15.o build/libavcodec_mpeg4audio_sample_rates.o build/libavcodec_sbrdsp.o build/init.o
	$(WASM_LD) $(LDFLAGS) -o $@ build/libavcodec_aacdec.o build/libavcodec_aacps_common.o build/libavcodec_aacps_float.o build/libavcodec_aacpsdsp_float.o build/libavcodec_aacsbr.o build/libavcodec_aactab.o build/libavcodec_adts_header.o build/libavcodec_cbrt_data.o build/libavcodec_kbdwin.o build/libavcodec_mdct15.o build/libavcodec_mpeg4audio_sample_rates.o build/libavcodec_sbrdsp.o build/init.o
	@echo "Built $(OUT) ($$(wc -c < $(OUT) | tr -d ' ') bytes)"

clean:
	rm -rf build $(OUT)
