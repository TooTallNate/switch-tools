# @tootallnate/ffmpeg-wasm/extensions/h263i-decoder
#
# H263I decoder.
#
# AUTOGENERATED by scripts/gen/. Do not edit by hand — re-run
# the generator after changing the upstream FFmpeg checkout.

WASI_SDK_VERSION ?= 25
WASI_SDK ?= /tmp/wasi-sdk
CC      = $(WASI_SDK)/bin/clang
WASM_LD = $(WASI_SDK)/bin/wasm-ld

SYSROOT = $(WASI_SDK)/share/wasi-sysroot

FFMPEG_BASE = ../../../build/ffmpeg
SHARED_INC  = ../../../c

OUT = h263i-decoder.so

BASE_CFLAGS = \
	--target=wasm32-wasip1 \
	--sysroot=$(SYSROOT) \
	-fPIC \
	-fvisibility=hidden \
	-O2 \
	-DHAVE_AV_CONFIG_H \
	-I$(FFMPEG_BASE) \
	-I$(FFMPEG_BASE)/libavcodec \
	-I$(FFMPEG_BASE)/libavformat \
	-I$(SHARED_INC) \
	-include shim.h \
	-include libavutil/internal.h \
	-Wno-implicit-fallthrough \
	-Wno-deprecated-declarations \
	-Wno-incompatible-pointer-types \
	-Wno-unused-but-set-variable \
	-Wno-unused-variable \
	-Wno-unused-function \
	-Wno-pointer-sign \
	-Wno-bitwise-op-parentheses \
	-Wno-shift-op-parentheses

LDFLAGS = \
	--shared \
	--no-entry \
	--export-dynamic \
	--allow-undefined \
	--gc-sections

.PHONY: all clean check-base

all: check-base $(OUT)

check-base:
	@if [ ! -d "$(FFMPEG_BASE)" ]; then \
		echo "ERROR: base FFmpeg checkout not found at $(FFMPEG_BASE)"; \
		echo "Run 'make setup-source' in $(realpath $(FFMPEG_BASE)/../..) first."; \
		exit 1; \
	fi

build:
	@mkdir -p build

build/init.o: init.c shim.h | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_h263_parser.o: ../../../build/ffmpeg/libavcodec/h263_parser.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_h263.o: ../../../build/ffmpeg/libavcodec/h263.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_h263data.o: ../../../build/ffmpeg/libavcodec/h263data.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_h263dec.o: ../../../build/ffmpeg/libavcodec/h263dec.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_h263dsp.o: ../../../build/ffmpeg/libavcodec/h263dsp.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_intelh263dec.o: ../../../build/ffmpeg/libavcodec/intelh263dec.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_ituh263dec.o: ../../../build/ffmpeg/libavcodec/ituh263dec.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_mpeg4video.o: ../../../build/ffmpeg/libavcodec/mpeg4video.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_mpeg4videodec.o: ../../../build/ffmpeg/libavcodec/mpeg4videodec.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

$(OUT): build/libavcodec_h263_parser.o build/libavcodec_h263.o build/libavcodec_h263data.o build/libavcodec_h263dec.o build/libavcodec_h263dsp.o build/libavcodec_intelh263dec.o build/libavcodec_ituh263dec.o build/libavcodec_mpeg4video.o build/libavcodec_mpeg4videodec.o build/init.o
	$(WASM_LD) $(LDFLAGS) -o $@ build/libavcodec_h263_parser.o build/libavcodec_h263.o build/libavcodec_h263data.o build/libavcodec_h263dec.o build/libavcodec_h263dsp.o build/libavcodec_intelh263dec.o build/libavcodec_ituh263dec.o build/libavcodec_mpeg4video.o build/libavcodec_mpeg4videodec.o build/init.o
	@echo "Built $(OUT) ($$(wc -c < $(OUT) | tr -d ' ') bytes)"

clean:
	rm -rf build $(OUT)
