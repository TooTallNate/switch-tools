$(OUT): build/libavcodec_aac_ac3_parser.o build/libavcodec_aac_adtstoasc_bsf.o build/libavcodec_ac3_channel_layout_tab.o build/libavcodec_ac3tab.o build/libavcodec_adts_header.o build/libavcodec_h264_mp4toannexb_bsf.o build/libavcodec_hevc_mp4toannexb_bsf.o build/libavcodec_mpeg4audio_sample_rates.o build/libavformat_adtsenc.o build/libavformat_apetag.o build/libavformat_id3v2enc.o build/libavformat_img2.o build/libavformat_latmenc.o build/libavformat_mpegtsenc.o build/libavformat_rawenc.o build/init.o
