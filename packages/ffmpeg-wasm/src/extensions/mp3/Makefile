# @tootallnate/ffmpeg-wasm/extensions/mp3
#
# MP3 decoder, demuxer, muxer.
#
# AUTOGENERATED by scripts/gen/. Do not edit by hand — re-run
# the generator after changing the upstream FFmpeg checkout.

WASI_SDK_VERSION ?= 25
WASI_SDK ?= /tmp/wasi-sdk
CC      = $(WASI_SDK)/bin/clang
WASM_LD = $(WASI_SDK)/bin/wasm-ld

SYSROOT = $(WASI_SDK)/share/wasi-sysroot

FFMPEG_BASE = ../../../build/ffmpeg
SHARED_INC  = ../../../c

OUT = mp3.so

BASE_CFLAGS = \
	--target=wasm32-wasip1 \
	--sysroot=$(SYSROOT) \
	-fPIC \
	-fvisibility=hidden \
	-O2 \
	-DHAVE_AV_CONFIG_H \
	-I$(FFMPEG_BASE) \
	-I$(FFMPEG_BASE)/libavcodec \
	-I$(FFMPEG_BASE)/libavformat \
	-I$(SHARED_INC) \
	-include shim.h \
	-include libavutil/internal.h \
	-Wno-implicit-fallthrough \
	-Wno-deprecated-declarations \
	-Wno-incompatible-pointer-types \
	-Wno-unused-but-set-variable \
	-Wno-unused-variable \
	-Wno-unused-function \
	-Wno-pointer-sign \
	-Wno-bitwise-op-parentheses \
	-Wno-shift-op-parentheses

LDFLAGS = \
	--shared \
	--no-entry \
	--export-dynamic \
	--allow-undefined \
	--gc-sections

.PHONY: all clean check-base

all: check-base $(OUT)

check-base:
	@if [ ! -d "$(FFMPEG_BASE)" ]; then \
		echo "ERROR: base FFmpeg checkout not found at $(FFMPEG_BASE)"; \
		echo "Run 'make setup-source' in $(realpath $(FFMPEG_BASE)/../..) first."; \
		exit 1; \
	fi

build:
	@mkdir -p build

build/init.o: init.c shim.h | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_mpegaudio_parser.o: ../../../build/ffmpeg/libavcodec/mpegaudio_parser.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_mpegaudiodec_fixed.o: ../../../build/ffmpeg/libavcodec/mpegaudiodec_fixed.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavformat_id3v2enc.o: ../../../build/ffmpeg/libavformat/id3v2enc.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavformat_mp3dec.o: ../../../build/ffmpeg/libavformat/mp3dec.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavformat_mp3enc.o: ../../../build/ffmpeg/libavformat/mp3enc.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavformat_rawenc.o: ../../../build/ffmpeg/libavformat/rawenc.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavformat_replaygain.o: ../../../build/ffmpeg/libavformat/replaygain.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

$(OUT): build/libavcodec_mpegaudio_parser.o build/libavcodec_mpegaudiodec_fixed.o build/libavformat_id3v2enc.o build/libavformat_mp3dec.o build/libavformat_mp3enc.o build/libavformat_rawenc.o build/libavformat_replaygain.o build/init.o
	$(WASM_LD) $(LDFLAGS) -o $@ build/libavcodec_mpegaudio_parser.o build/libavcodec_mpegaudiodec_fixed.o build/libavformat_id3v2enc.o build/libavformat_mp3dec.o build/libavformat_mp3enc.o build/libavformat_rawenc.o build/libavformat_replaygain.o build/init.o
	@echo "Built $(OUT) ($$(wc -c < $(OUT) | tr -d ' ') bytes)"

clean:
	rm -rf build $(OUT)
