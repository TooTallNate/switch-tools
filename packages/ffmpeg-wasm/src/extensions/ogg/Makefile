$(OUT): build/libavcodec_golomb.o build/libavformat_flac_picture.o build/libavformat_oggdec.o build/libavformat_oggenc.o build/libavformat_oggparsecelt.o build/libavformat_oggparsedirac.o build/libavformat_oggparseflac.o build/libavformat_oggparseogm.o build/libavformat_oggparseopus.o build/libavformat_oggparseskeleton.o build/libavformat_oggparsespeex.o build/libavformat_oggparsetheora.o build/libavformat_oggparsevorbis.o build/libavformat_oggparsevp8.o build/libavformat_replaygain.o build/libavformat_vorbiscomment.o build/init.o
	$(WASM_LD) $(LDFLAGS) -o $@ build/libavcodec_golomb.o build/libavformat_flac_picture.o build/libavformat_oggdec.o build/libavformat_oggenc.o build/libavformat_oggparsecelt.o build/libavformat_oggparsedirac.o build/libavformat_oggparseflac.o build/libavformat_oggparseogm.o build/libavformat_oggparseopus.o build/libavformat_oggparseskeleton.o build/libavformat_oggparsespeex.o build/libavformat_oggparsetheora.o build/libavformat_oggparsevorbis.o build/libavformat_oggparsevp8.o build/libavformat_replaygain.o build/libavformat_vorbiscomment.o build/init.o
	@echo "Built $(OUT) ($$(wc -c < $(OUT) | tr -d ' ') bytes)"

clean:
	rm -rf build $(OUT)
