# AUTOGENERATED by scripts/gen/. Do not edit by hand — re-run
# the generator after changing the upstream FFmpeg checkout.

WASI_SDK_VERSION ?= 25
WASI_SDK ?= /tmp/wasi-sdk
CC      = $(WASI_SDK)/bin/clang
WASM_LD = $(WASI_SDK)/bin/wasm-ld

SYSROOT = $(WASI_SDK)/share/wasi-sysroot

FFMPEG_BASE = ../../../build/ffmpeg
SHARED_INC  = ../../../c

OUT = dca-decoder.so

BASE_CFLAGS = \
	--target=wasm32-wasip1 \
	--sysroot=$(SYSROOT) \
	-fPIC \
	-fvisibility=hidden \
	-O2 \
	-DHAVE_AV_CONFIG_H \
	-I$(FFMPEG_BASE) \
	-I$(FFMPEG_BASE)/libavcodec \
	-I$(FFMPEG_BASE)/libavformat \
	-I$(SHARED_INC) \
	-include shim.h \
	-include libavutil/internal.h \
	-Wno-implicit-fallthrough \
	-Wno-deprecated-declarations \
	-Wno-incompatible-pointer-types \
	-Wno-unused-but-set-variable \
	-Wno-unused-variable \
	-Wno-unused-function \
	-Wno-pointer-sign \
	-Wno-bitwise-op-parentheses \
	-Wno-shift-op-parentheses

LDFLAGS = \
	--shared \
	--no-entry \
	--export-dynamic \
	--allow-undefined \
	--gc-sections

.PHONY: all clean check-base

all: check-base $(OUT)

check-base:
	@if [ ! -d "$(FFMPEG_BASE)" ]; then \
		echo "ERROR: base FFmpeg checkout not found at $(FFMPEG_BASE)"; \
		echo "Run 'make setup-source' in $(realpath $(FFMPEG_BASE)/../..) first."; \
		exit 1; \
	fi

build:
	@mkdir -p build

build/init.o: init.c shim.h | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_dca_core.o: ../../../build/ffmpeg/libavcodec/dca_core.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_dca_exss.o: ../../../build/ffmpeg/libavcodec/dca_exss.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_dca_lbr.o: ../../../build/ffmpeg/libavcodec/dca_lbr.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_dca_sample_rate_tab.o: ../../../build/ffmpeg/libavcodec/dca_sample_rate_tab.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_dca_xll.o: ../../../build/ffmpeg/libavcodec/dca_xll.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_dca.o: ../../../build/ffmpeg/libavcodec/dca.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_dcadata.o: ../../../build/ffmpeg/libavcodec/dcadata.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_dcadct.o: ../../../build/ffmpeg/libavcodec/dcadct.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_dcadec.o: ../../../build/ffmpeg/libavcodec/dcadec.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_dcadsp.o: ../../../build/ffmpeg/libavcodec/dcadsp.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_dcahuff.o: ../../../build/ffmpeg/libavcodec/dcahuff.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_synth_filter.o: ../../../build/ffmpeg/libavcodec/synth_filter.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

$(OUT): build/libavcodec_dca_core.o build/libavcodec_dca_exss.o build/libavcodec_dca_lbr.o build/libavcodec_dca_sample_rate_tab.o build/libavcodec_dca_xll.o build/libavcodec_dca.o build/libavcodec_dcadata.o build/libavcodec_dcadct.o build/libavcodec_dcadec.o build/libavcodec_dcadsp.o build/libavcodec_dcahuff.o build/libavcodec_synth_filter.o build/init.o
	$(WASM_LD) $(LDFLAGS) -o $@ build/libavcodec_dca_core.o build/libavcodec_dca_exss.o build/libavcodec_dca_lbr.o build/libavcodec_dca_sample_rate_tab.o build/libavcodec_dca_xll.o build/libavcodec_dca.o build/libavcodec_dcadata.o build/libavcodec_dcadct.o build/libavcodec_dcadec.o build/libavcodec_dcadsp.o build/libavcodec_dcahuff.o build/libavcodec_synth_filter.o build/init.o
	@echo "Built $(OUT) ($$(wc -c < $(OUT) | tr -d ' ') bytes)"

clean:
	rm -rf build $(OUT)
