# @tootallnate/ffmpeg-wasm/extensions/tta
#
# TTA decoder, encoder, demuxer, muxer.
#
# AUTOGENERATED by scripts/gen/. Do not edit by hand — re-run
# the generator after changing the upstream FFmpeg checkout.

WASI_SDK_VERSION ?= 25
WASI_SDK ?= /tmp/wasi-sdk
CC      = $(WASI_SDK)/bin/clang
WASM_LD = $(WASI_SDK)/bin/wasm-ld

SYSROOT = $(WASI_SDK)/share/wasi-sysroot

FFMPEG_BASE = ../../../build/ffmpeg
SHARED_INC  = ../../../c

OUT = tta.so

BASE_CFLAGS = \
	--target=wasm32-wasip1 \
	--sysroot=$(SYSROOT) \
	-fPIC \
	-fvisibility=hidden \
	-O2 \
	-DHAVE_AV_CONFIG_H \
	-I$(FFMPEG_BASE) \
	-I$(FFMPEG_BASE)/libavcodec \
	-I$(FFMPEG_BASE)/libavformat \
	-I$(SHARED_INC) \
	-include shim.h \
	-include libavutil/internal.h \
	-Wno-implicit-fallthrough \
	-Wno-deprecated-declarations \
	-Wno-incompatible-pointer-types \
	-Wno-unused-but-set-variable \
	-Wno-unused-variable \
	-Wno-unused-function \
	-Wno-pointer-sign \
	-Wno-bitwise-op-parentheses \
	-Wno-shift-op-parentheses

LDFLAGS = \
	--shared \
	--no-entry \
	--export-dynamic \
	--allow-undefined \
	--gc-sections

.PHONY: all clean check-base

all: check-base $(OUT)

check-base:
	@if [ ! -d "$(FFMPEG_BASE)" ]; then \
		echo "ERROR: base FFmpeg checkout not found at $(FFMPEG_BASE)"; \
		echo "Run 'make setup-source' in $(realpath $(FFMPEG_BASE)/../..) first."; \
		exit 1; \
	fi

build:
	@mkdir -p build

build/init.o: init.c shim.h | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_tta.o: ../../../build/ffmpeg/libavcodec/tta.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_ttadata.o: ../../../build/ffmpeg/libavcodec/ttadata.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_ttadsp.o: ../../../build/ffmpeg/libavcodec/ttadsp.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_ttaenc.o: ../../../build/ffmpeg/libavcodec/ttaenc.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_ttaencdsp.o: ../../../build/ffmpeg/libavcodec/ttaencdsp.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavformat_apetag.o: ../../../build/ffmpeg/libavformat/apetag.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavformat_img2.o: ../../../build/ffmpeg/libavformat/img2.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavformat_tta.o: ../../../build/ffmpeg/libavformat/tta.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavformat_ttaenc.o: ../../../build/ffmpeg/libavformat/ttaenc.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

$(OUT): build/libavcodec_tta.o build/libavcodec_ttadata.o build/libavcodec_ttadsp.o build/libavcodec_ttaenc.o build/libavcodec_ttaencdsp.o build/libavformat_apetag.o build/libavformat_img2.o build/libavformat_tta.o build/libavformat_ttaenc.o build/init.o
	$(WASM_LD) $(LDFLAGS) -o $@ build/libavcodec_tta.o build/libavcodec_ttadata.o build/libavcodec_ttadsp.o build/libavcodec_ttaenc.o build/libavcodec_ttaencdsp.o build/libavformat_apetag.o build/libavformat_img2.o build/libavformat_tta.o build/libavformat_ttaenc.o build/init.o
	@echo "Built $(OUT) ($$(wc -c < $(OUT) | tr -d ' ') bytes)"

clean:
	rm -rf build $(OUT)
