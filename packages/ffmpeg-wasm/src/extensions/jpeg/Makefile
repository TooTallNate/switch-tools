$(OUT): build/libavcodec_exif.o build/libavcodec_j2kenc.o build/libavcodec_jpeg2000.o build/libavcodec_jpeg2000dec.o build/libavcodec_jpeg2000dsp.o build/libavcodec_jpeg2000dwt.o build/libavcodec_jpegls.o build/libavcodec_jpeglsdec.o build/libavcodec_jpeglsenc.o build/libavcodec_jpegtables.o build/libavcodec_ljpegenc.o build/libavcodec_mjpegbdec.o build/libavcodec_mjpegdec_common.o build/libavcodec_mjpegdec.o build/libavcodec_mjpegenc_common.o build/libavcodec_mjpegenc_huffman.o build/libavcodec_mjpegenc.o build/libavcodec_mqc.o build/libavcodec_mqcdec.o build/libavcodec_mqcenc.o build/libavcodec_tiff_common.o build/libavformat_mj2kdec.o build/libavformat_rawdec.o build/libavformat_rawenc.o build/init.o
	$(WASM_LD) $(LDFLAGS) -o $@ build/libavcodec_exif.o build/libavcodec_j2kenc.o build/libavcodec_jpeg2000.o build/libavcodec_jpeg2000dec.o build/libavcodec_jpeg2000dsp.o build/libavcodec_jpeg2000dwt.o build/libavcodec_jpegls.o build/libavcodec_jpeglsdec.o build/libavcodec_jpeglsenc.o build/libavcodec_jpegtables.o build/libavcodec_ljpegenc.o build/libavcodec_mjpegbdec.o build/libavcodec_mjpegdec_common.o build/libavcodec_mjpegdec.o build/libavcodec_mjpegenc_common.o build/libavcodec_mjpegenc_huffman.o build/libavcodec_mjpegenc.o build/libavcodec_mqc.o build/libavcodec_mqcdec.o build/libavcodec_mqcenc.o build/libavcodec_tiff_common.o build/libavformat_mj2kdec.o build/libavformat_rawdec.o build/libavformat_rawenc.o build/init.o
	@echo "Built $(OUT) ($$(wc -c < $(OUT) | tr -d ' ') bytes)"

clean:
	rm -rf build $(OUT)
