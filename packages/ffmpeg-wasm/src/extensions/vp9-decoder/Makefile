	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_vp9recon.o: ../../../build/ffmpeg/libavcodec/vp9recon.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

$(OUT): build/libavcodec_vp56rac.o build/libavcodec_vp9_parser.o build/libavcodec_vp9_superframe_split_bsf.o build/libavcodec_vp9.o build/libavcodec_vp9block.o build/libavcodec_vp9data.o build/libavcodec_vp9dsp_10bpp.o build/libavcodec_vp9dsp_12bpp.o build/libavcodec_vp9dsp_8bpp.o build/libavcodec_vp9dsp.o build/libavcodec_vp9lpf.o build/libavcodec_vp9mvs.o build/libavcodec_vp9prob.o build/libavcodec_vp9recon.o build/init.o
	$(WASM_LD) $(LDFLAGS) -o $@ build/libavcodec_vp56rac.o build/libavcodec_vp9_parser.o build/libavcodec_vp9_superframe_split_bsf.o build/libavcodec_vp9.o build/libavcodec_vp9block.o build/libavcodec_vp9data.o build/libavcodec_vp9dsp_10bpp.o build/libavcodec_vp9dsp_12bpp.o build/libavcodec_vp9dsp_8bpp.o build/libavcodec_vp9dsp.o build/libavcodec_vp9lpf.o build/libavcodec_vp9mvs.o build/libavcodec_vp9prob.o build/libavcodec_vp9recon.o build/init.o
	@echo "Built $(OUT) ($$(wc -c < $(OUT) | tr -d ' ') bytes)"

clean:
	rm -rf build $(OUT)
