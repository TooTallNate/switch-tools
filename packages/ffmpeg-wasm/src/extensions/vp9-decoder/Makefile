#
# VP9 decoder.
#
# AUTOGENERATED by scripts/gen/. Do not edit by hand — re-run
# the generator after changing the upstream FFmpeg checkout.

WASI_SDK_VERSION ?= 25
WASI_SDK ?= /tmp/wasi-sdk
CC      = $(WASI_SDK)/bin/clang
WASM_LD = $(WASI_SDK)/bin/wasm-ld

SYSROOT = $(WASI_SDK)/share/wasi-sysroot

FFMPEG_BASE = ../../../build/ffmpeg
SHARED_INC  = ../../../c

OUT = vp9-decoder.so

BASE_CFLAGS = \
	--target=wasm32-wasip1 \
	--sysroot=$(SYSROOT) \
	-fPIC \
	-fvisibility=hidden \
	-O2 \
	-DHAVE_AV_CONFIG_H \
	-I$(FFMPEG_BASE) \
	-I$(FFMPEG_BASE)/libavcodec \
	-I$(FFMPEG_BASE)/libavformat \
	-I$(SHARED_INC) \
	-include shim.h \
	-include libavutil/internal.h \
	-Wno-implicit-fallthrough \
	-Wno-deprecated-declarations \
	-Wno-incompatible-pointer-types \
	-Wno-unused-but-set-variable \
	-Wno-unused-variable \
	-Wno-unused-function \
	-Wno-pointer-sign \
	-Wno-bitwise-op-parentheses \
	-Wno-shift-op-parentheses

LDFLAGS = \
	--shared \
	--no-entry \
	--export-dynamic \
	--allow-undefined \
	--gc-sections

.PHONY: all clean check-base

all: check-base $(OUT)

check-base:
	@if [ ! -d "$(FFMPEG_BASE)" ]; then \
		echo "ERROR: base FFmpeg checkout not found at $(FFMPEG_BASE)"; \
		echo "Run 'make setup-source' in $(realpath $(FFMPEG_BASE)/../..) first."; \
		exit 1; \
	fi

build:
	@mkdir -p build

build/init.o: init.c shim.h | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_vp56rac.o: ../../../build/ffmpeg/libavcodec/vp56rac.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_vp9_parser.o: ../../../build/ffmpeg/libavcodec/vp9_parser.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_vp9_superframe_split_bsf.o: ../../../build/ffmpeg/libavcodec/vp9_superframe_split_bsf.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_vp9.o: ../../../build/ffmpeg/libavcodec/vp9.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_vp9block.o: ../../../build/ffmpeg/libavcodec/vp9block.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_vp9data.o: ../../../build/ffmpeg/libavcodec/vp9data.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_vp9dsp_10bpp.o: ../../../build/ffmpeg/libavcodec/vp9dsp_10bpp.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_vp9dsp_12bpp.o: ../../../build/ffmpeg/libavcodec/vp9dsp_12bpp.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_vp9dsp_8bpp.o: ../../../build/ffmpeg/libavcodec/vp9dsp_8bpp.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_vp9dsp.o: ../../../build/ffmpeg/libavcodec/vp9dsp.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_vp9lpf.o: ../../../build/ffmpeg/libavcodec/vp9lpf.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

build/libavcodec_vp9mvs.o: ../../../build/ffmpeg/libavcodec/vp9mvs.c | build check-base
	$(CC) $(BASE_CFLAGS) -c -o $@ $<

