{
  "name": "@tootallnate/ffmpeg-wasm",
  "version": "0.0.1",
  "type": "module",
  "description": "FFmpeg WebAssembly runtime with dynamically-loaded codec extensions.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ffmpeg.wasm": "./dist/ffmpeg.wasm"
  },
  "files": [
    "dist",
    "LICENSE.LGPL-2.1"
  ],
  "scripts": {
    "build:wasm": "make",
    "build:ts": "tsc",
    "build": "if [ -x /tmp/wasi-sdk/bin/clang ] && [ -d build/ffmpeg ]; then make; fi && tsc && cp src/ffmpeg.wasm dist/ffmpeg.wasm",
    "test": "vitest run --passWithNoTests"
  },
  "keywords": [
    "ffmpeg",
    "wasm",
    "webassembly",
    "video",
    "codec",
    "decoder",
    "wasi",
    "dynamic-linking",
    "shared-library"
  ],
  "author": "Nathan Rajlich <n@n8.io>",
  "license": "LGPL-2.1-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/TooTallNate/switch-tools",
    "directory": "packages/ffmpeg-wasm"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^2.1.5"
  }
}
